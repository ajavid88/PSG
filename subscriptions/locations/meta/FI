  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
